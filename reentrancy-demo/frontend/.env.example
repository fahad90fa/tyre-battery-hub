# Optional. The demo works with zero configuration — these are just overrides.
# Copy to `.env` inside the frontend/ folder if you want to change them.

# Local Hardhat JSON-RPC endpoint.
VITE_RPC_URL=http://127.0.0.1:8545

# Hardhat's first well-known dev account (PUBLIC throwaway key, safe to commit).
# Powers the "Local dev wallet" connection mode so the demo runs without MetaMask.
VITE_LOCAL_PRIVATE_KEY=0xac0974bec39a17e36ba4a6b4d238ff944bacb478cbed5efcae784d7bf4f2ff80
