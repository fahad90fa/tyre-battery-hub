# The demo runs fully locally and needs NO secrets to work.
# This file documents the only two optional knobs.

# JSON-RPC endpoint of your local Hardhat node.
# The frontend falls back to this exact value if unset.
VITE_RPC_URL=http://127.0.0.1:8545

# Hardhat's first well-known dev account private key.
# It is a PUBLIC, throwaway key baked into every Hardhat install — safe to
# commit, worthless on any real network. Used only by the "Local dev wallet"
# mode so the demo works without MetaMask.
VITE_LOCAL_PRIVATE_KEY=0xac0974bec39a17e36ba4a6b4d238ff944bacb478cbed5efcae784d7bf4f2ff80
